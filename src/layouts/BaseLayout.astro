---
import SEOHead from '@/components/SEOHead.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import '@/styles/global.css';

export type Props = {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  keywords?: string[];
  publishedTime?: string;
  modifiedTime?: string;
};
const { title, description, canonical, image, imageAlt, type = 'website', noindex = false, keywords = [], publishedTime, modifiedTime } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEOHead title={title} description={description} canonical={canonical} image={image} imageAlt={imageAlt} type={type} noindex={noindex} keywords={keywords} publishedTime={publishedTime} modifiedTime={modifiedTime} />
  </head>
  <body>
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
