---
import type { Tool } from '@/data/tools';
import LocalProcessingBadge from './LocalProcessingBadge.astro';
export type Props = { tool: Tool };
const { tool } = Astro.props;
const isUrl = tool.id === 'url-cleaner';
const isResize = tool.id === 'resize-image';
const isConvert = tool.id === 'convert-image';
const isPdfRange = tool.id === 'split-pdf' || tool.id === 'remove-pdf-pages';
const isPdfMetadata = tool.id === 'remove-pdf-metadata' || tool.id === 'remove-pdf-hidden-data';
const isHash = tool.id === 'sha256';
const inputId = `${tool.id}-file-input`;
const helpId = `${tool.id}-help`;
---
<section class="tool-shell" data-tool-root data-tool-kind={tool.id} data-output-slug={tool.slug} aria-labelledby={`${tool.id}-tool-title`}>
  <div class="tool-card-main">
    <h2 id={`${tool.id}-tool-title`} class="sr-only">{tool.h1} tool</h2>
    <LocalProcessingBadge label={isUrl ? 'Runs locally in your browser - pasted URLs are not sent to a server.' : undefined} />
    <p id={helpId} class="tool-note"><strong>{isUrl ? 'Supported input:' : 'Supported files:'}</strong> {tool.acceptedFormats}</p>

    {isUrl ? (
      <div class="url-tool-panel">
        <label for="url-input">Paste a full URL</label>
        <textarea id="url-input" data-url-input rows="5" aria-describedby={helpId} placeholder="https://example.com/page?utm_source=newsletter&fbclid=..."></textarea>
        <button class="button primary" type="button" data-process>{tool.cta}</button>
      </div>
    ) : (
      <div class="file-tool-panel">
        <label class="dropzone" data-dropzone for={inputId}>
          <input id={inputId} data-file-input type="file" accept={tool.accept} multiple={tool.multiple} aria-describedby={helpId} />
          <span class="upload-icon" aria-hidden="true">↥</span>
          <strong>{tool.cta}</strong>
          <small>{tool.acceptedFormats}</small>
        </label>
        <div class="selected-files" data-selected-files aria-live="polite" hidden></div>
        {tool.id === 'merge-pdf' && <p class="helper-text">After selecting PDFs, use the up and down controls to set merge order.</p>}
      </div>
    )}

    {isResize && (
      <div class="settings-panel" data-settings hidden>
        <h2>Resize settings</h2>
        <div class="form-grid">
          <label>Width (px)<input data-width type="number" min="1" max="20000" inputmode="numeric" /></label>
          <label>Height (px)<input data-height type="number" min="1" max="20000" inputmode="numeric" /></label>
          <label>Output format<select data-output-format><option value="same">Same as input</option><option value="image/jpeg">JPG</option><option value="image/png">PNG</option><option value="image/webp">WebP</option></select></label>
          <label>Quality<input data-quality type="number" min="0.1" max="1" step="0.05" value="0.92" /></label>
        </div>
        <label class="checkbox"><input data-lock-aspect type="checkbox" checked /> Preserve aspect ratio</label>
      </div>
    )}

    {isConvert && (
      <div class="settings-panel" data-settings hidden>
        <h2>Convert settings</h2>
        <div class="form-grid">
          <label>Output format<select data-output-format><option value="image/jpeg">JPG</option><option value="image/png">PNG</option><option value="image/webp">WebP</option></select></label>
          <label>Quality for JPG/WebP<input data-quality type="number" min="0.1" max="1" step="0.05" value="0.92" /></label>
        </div>
        <p class="helper-text">JPG does not support transparency. Transparent pixels are drawn over a white background.</p>
      </div>
    )}

    {isPdfRange && (
      <div class="settings-panel" data-settings hidden>
        <h2>{tool.id === 'split-pdf' ? 'Split settings' : 'Pages to remove'}</h2>
        <p class="helper-text" data-page-count aria-live="polite"></p>
        <label>Page ranges <input data-page-ranges type="text" inputmode="text" placeholder="1-3, 5, 8-10" /></label>
      </div>
    )}

    {isHash && (
      <div class="settings-panel" data-settings hidden>
        <h2>Compare hash</h2>
        <label>Expected SHA-256 hash <input data-expected-hash type="text" autocomplete="off" spellcheck="false" placeholder="Paste expected 64-character hash" /></label>
      </div>
    )}

    {!isUrl && <button class="button primary process-button" type="button" data-process disabled>{tool.id === 'remove-exif' ? 'Remove Metadata' : tool.id === 'remove-gps' ? 'Remove GPS Data' : tool.id === 'metadata-viewer' ? 'View Metadata' : tool.id === 'resize-image' ? 'Resize Image' : tool.id === 'convert-image' ? 'Convert Image' : tool.id === 'merge-pdf' ? 'Merge PDF' : tool.id === 'split-pdf' ? 'Split PDF' : tool.id === 'remove-pdf-pages' ? 'Remove Pages' : isPdfMetadata ? 'Clean PDF' : 'Calculate SHA-256'}</button>}

    <div class="progress-card" data-progress-card role="status" aria-live="polite" hidden>
      <p class="progress-label" data-progress-label></p>
      <div class="progress-track" aria-hidden="true"><span data-progress-bar style="width: 0%"></span></div>
    </div>
    <div class="error-message" role="alert" data-error hidden>
      <strong data-error-title></strong>
      <p></p>
    </div>
    <div class="result-card" aria-live="polite" data-result hidden>
      <h2 data-result-heading></h2>
      <div data-result-summary></div>
      <div class="result-actions" data-result-actions></div>
    </div>
  </div>
</section>
<script>
  import { initToolRuntime } from '@/tools/toolRuntime';
  initToolRuntime();
</script>
